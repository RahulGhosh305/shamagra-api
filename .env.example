NODE_ENVIRONMENT = development

# HOST CONFIGURATION
HOST_NAME = localhost
HOST_PORT = 3333

# Cors allow
CORS_ORIGIN = "http://example1.com, http://example2.com"

# Mongo URI
MONGODB_URL = mongodb://localhost:27017/webswift

# JWT configuration
JWT_BASIC_USER = demo-client
JWT_BASIC_SECRET = demo-secret
JWT_ACCESS_SECRET = goribErAccessToken
JWT_REFRESH_SECRET = goribErRefreshToken
JWT_ACCESS_EXPIRATION_MINUTES = 4320
JWT_REFRESH_EXPIRATION_DAYS = 30

# hacker slow down and blocking
WINDOW_BLOCK_SECOND = 30
PER_WINDOW_MAX_REQUEST = 30
RESPONSE_DELAY_SECOND = .5

# email
SENDGRID_API_KEY=

# Temporary Pass
MASTER_PASS=

# S3
S3_ACCESS_KEY_ID =
S3_ACCESS_KEY_SECRET =
S3_REGION =
S3_BUCKET_NAME =
S3_DIR_NAME =
S3_STORAGE_BASE_URL =

# SMS
MT_BASE_URL =
MT_SENDER_ID =
MT_AUTH_TOKEN =
